# ============ localTool 本地工具服务配置 ============
# 服务名：maomao-localtool（替代闭源 Go 二进制，监听 :18080）
# 用法：复制为 .env 后按需修改，启动前由运行环境注入（如 PM2 / dotenv / 直接 export）

# ── 监听端口 ──
# 本地工具服务监听的端口。前端 config.js 的 LOCAL_ENGINE.port 必须与此一致。
# 默认 18080；修改后需同步改 src/_engine/config.js 的 LOCAL_ENGINE.port。
PORT=18080

# ── 数据存储目录 ──
# SQLite 数据库 + 上传文件的存放根目录。
# 不配则默认 ~/.maomao-localtool（见 src/db/database.ts:getDataDir/getUploadDir）。
MAOMAO_DATA_DIR=

# ── 绑定地址 ──
# 注意：代码内绑定死 127.0.0.1（仅本机），未做环境变量开关。
# 如需允许局域网访问，需改 index.ts 的 server.listen(PORT, '127.0.0.1')。
# 出于安全（路径遍历已做防护，但代理/文件接口仍仅限本机）默认不开放。

# ============ 与 9004 网关的关系 ============
# localTool 只负责：KV 存储、文件上传/读取/缩略图、任务/资源管理、本地代理、剪映发送。
# 生图/视频/聊天等 AI 请求由前端直接打到 9004 网关（apimart-gateway），
# 再由网关转发 Lovart。本服务不持有任何 Lovart 凭证，也无会员/权益校验。
