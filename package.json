{
  "name": "yimao-ai-canvas",
  "private": true,
  "version": "1.3.5",
  "type": "module",
  "description": "猫猫AI画布插件 - Chrome Extension MV3 with AI Canvas",
  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=1024 vite build",
    "preview": "vite preview",
    "dev:all": "concurrently -n web,tool,gw -c cyan,green,yellow \"vite\" \"npm --prefix localTool run dev\" \"cd apimart-gateway && uvicorn main:app --host 127.0.0.1 --port 9004\""
  },
  "dependencies": {
