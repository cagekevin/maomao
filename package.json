    "@babel/traverse": "^8.0.4",
    "@babel/types": "^8.0.4",
    "@xyflow/react": "^12.3.6",
    "acorn": "^8.17.0",
    "acorn-jsx": "^5.3.2",
    "localforage": "^1.10.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.5",
