# ============ Lovart 上游（真正干活的服务）============
LOVART_BASE_URL=https://lgw.lovart.ai
# 单账号兜底：所有用户共用这一对 Lovart AK/SK（不配 USER_KEYS 时用这个）
LOVART_ACCESS_KEY=ak_xxxx
LOVART_SECRET_KEY=sk_xxxx

# 可选：过 Cloudflare 时带上 __cf_bm cookie（客户端层自动读取）
CF_BM=
# 可选：处于 TLS 拦截代理后设 1 关闭证书校验（Mac/公司代理常见）
LOVART_INSECURE_SSL=

# ============ 多租户（可选）============
# 对外用户 key -> Lovart AK|SK 的字符串映射。配了它就按用户隔离，用户永远看不到你的上游凭证。
# 注意：gateway 用 "key":"ak|sk" 字符串格式（与 relay 的嵌套字典不同）。
# 例：USER_KEYS={"sk-user-abc":"ak_111|sk_111","sk-user-def":"ak_222|sk_222"}
USER_KEYS={}

# ============ 网关行为 ============
# 开放中继开关（默认 false）。true=任意/无 Bearer 都用默认凭据（仅内网/信任环境）。
# 保持 false 且未配 USER_KEYS 时，任何请求都 401，绝不静默裸奔到默认凭据。
OPEN_RELAY=false

# 遇到高成本确认（视频等）是否自动确认继续。无人值守中转站通常 true。
AUTO_CONFIRM=true

# 生成模式：fast（花积分不排队）/ unlimited（免费排队）/ 留空=沿用账号当前设置
LOVART_MODE=

# chat 线程级推理模式（thinking=深度推理 / fast=快速；仅 chat 用，不碰图/视频的账号级模式）
LOVART_CHAT_MODE=thinking

# Lovart 请求总超时（秒）
LOVART_TIMEOUT=600

# 对外任务结果链接展示的有效期（秒）
TASK_RESULT_TTL=86400

# /v1/chat/completions 同步等待生成的最长秒数
CHAT_SYNC_TIMEOUT=180

# 说明：webhook 重试上限/间隔为代码常量（WEBHOOK_MAX_RETRIES=3 / WEBHOOK_RETRY_INTERVAL=10 秒），
# 非环境变量；路径前缀固定 /v1/openapi，无 LOVART_PATH_PREFIX 开关。
