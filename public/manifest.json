{
  "manifest_version": 3,
  "name": "🐱猫猫画布",
  "version": "1.3.5",
  "description": "🐱猫猫画布 - 画布/资源/多开三Tab应用",
  "permissions": [
    "contextMenus",
    "storage",
    "unlimitedStorage",
    "cookies",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "打开一毛AI助手",
    "default_icon": {
      "16": "cat-icon.svg",
      "48": "cat-icon.svg",
      "128": "cat-icon.svg"
    }
  },
  "icons": {
    "16": "cat-icon.svg",
    "48": "cat-icon.svg",
    "128": "cat-icon.svg"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "*.svg",
        "*.png",
        "*.jpg",
        "*.jpeg",
        "*.css",
        "mediapipe/*",
        "mediapipe/wasm/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}